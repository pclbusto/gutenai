    def on_open_epub_response(self, dialog, response):
        """Manejar respuesta del diálogo de apertura"""
        if response == Gtk.ResponseType.ACCEPT:
            file = dialog.get_file()
            path = file.get_path()
            self.load_epub(path)
        dialog.destroy()
    
    def load_epub(self, path: str):
        """Cargar archivo EPUB"""
        if self.epub_manager.load_epub(path):
            filename = os.path.basename(path)
            self.book_title.set_text(filename)
            self.left_sidebar.load_structure()
            
            # Switch to text editor if we have text resources
            if self.epub_manager.resources['text']:
                first_text = self.epub_manager.resources['text'][0]
                self.on_resource_selected(first_text['item'], first_text['type'])
            else:
                self.editor_stack.set_visible_child_name("welcome")
        else:
            # Show error dialog
            self.show_error_dialog("Failed to load EPUB", "The selected file could not be opened as an EPUB.")
    
    def save_current_resource(self, action=None, param=None):
        """Guardar recurso actual"""
        if not self.current_resource:
            return
        
        try:
            content = ""
            
            if self.current_editor_mode == "text":
                content = self.text_editor.get_content()
            elif self.current_editor_mode == "css":
                content = self.css_editor.get_content()
            else:
                print("Cannot save this resource type")
                return
            
            # Update the ebooklib item
            self.current_resource.set_content(content.encode('utf-8'))
            print(f"Saved {self.current_resource.get_name()}")
            
            # Show success message
            toast = Adw.Toast.new("File saved successfully")
            toast.set_timeout(2)
            
            # Add toast to window if it has a toast overlay
            if hasattr(self, 'toast_overlay'):
                self.toast_overlay.add_toast(toast)
            
        except Exception as e:
            self.show_error_dialog("Save Error", f"Failed to save file: {str(e)}")
    
    def export_epub(self, action=None, param=None):
        """Exportar EPUB actual"""
        if not self.epub_manager.book:
            self.show_error_dialog("No Book Loaded", "Please load an EPUB file first.")
            return
        
        dialog = Gtk.FileChooserDialog(
            title="Export EPUB As...",
            parent=self,
            action=Gtk.FileChooserAction.SAVE
        )
        dialog.add_buttons(
            "_Cancel", Gtk.ResponseType.CANCEL,
            "_Save", Gtk.ResponseType.ACCEPT
        )
        
        # Set default filename
        dialog.set_current_name("exported_book.epub")
        
        # Add EPUB filter
        filter_epub = Gtk.FileFilter()
        filter_epub.set_name("EPUB files")
        filter_epub.add_pattern("*.epub")
        dialog.add_filter(filter_epub)
        
        dialog.connect("response", self.on_export_epub_response)
        dialog.show()
    
    def on_export_epub_response(self, dialog, response):
        """Manejar respuesta del diálogo de exportación"""
        if response == Gtk.ResponseType.ACCEPT:
            file = dialog.get_file()
            path = file.get_path()
            
            # Ensure .epub extension
            if not path.endswith('.epub'):
                path += '.epub'
            
            try:
                epub.write_epub(path, self.epub_manager.book)
                print(f"EPUB exported to: {path}")
                
                # Show success message
                toast = Adw.Toast.new(f"EPUB exported successfully")
                toast.set_timeout(3)
                
            except Exception as e:
                self.show_error_dialog("Export Error", f"Failed to export EPUB: {str(e)}")
        
        dialog.destroy()
    
