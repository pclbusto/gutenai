    def on_resource_selected(self, item, item_type):
        """Manejar selección de recurso"""
        self.current_resource = item
        self.resource_label.set_text(item.get_name())
        
        # Switch to appropriate editor
        if item_type == "html":
            self.switch_to_text_editor(item)
        elif item_type == "css":
            self.switch_to_css_editor(item)
        elif item_type == "image":
            self.switch_to_image_viewer(item)
        else:
            # Default to text editor for other types
            self.switch_to_text_editor(item)
    
    def switch_to_text_editor(self, item):
        """Cambiar al editor de texto"""
        self.current_editor_mode = "text"
        self.editor_stack.set_visible_child_name("text")
        self.mode_label.set_text("HTML Editor")
        
        try:
            content = item.get_content().decode('utf-8')
            self.text_editor.set_content(content)
            self.right_panel.update_preview(content, "html")
        except Exception as e:
            print(f"Error loading text content: {e}")
    
    def switch_to_css_editor(self, item):
        """Cambiar al editor CSS"""
        self.current_editor_mode = "css"
        self.editor_stack.set_visible_child_name("css")
        self.mode_label.set_text("CSS Editor")
        
        try:
            content = item.get_content().decode('utf-8')
            self.css_editor.set_content(content)
            self.right_panel.update_preview(content, "css")
        except Exception as e:
            print(f"Error loading CSS content: {e}")
    
    def switch_to_image_viewer(self, item):
        """Cambiar al visor de imágenes"""
        self.current_editor_mode = "image"
        self.editor_stack.set_visible_child_name("image")
        self.mode_label.set_text("Image Viewer")
        
        try:
            # Create temporary file
            if self.temp_dir is None:
                self.temp_dir = tempfile.mkdtemp()
            
            temp_path = os.path.join(self.temp_dir, item.get_name())
            with open(temp_path, 'wb') as f:
                f.write(item.get_content())
            
            self.image_viewer.set_image(item, temp_path)
            self.right_panel.update_preview(temp_path, "image")
            
        except Exception as e:
            print(f"Error loading image: {e}")
    
