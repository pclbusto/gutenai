        # Fullscreen button
        fullscreen_btn = Gtk.Button.new_from_icon_name("view-fullscreen-symbolic")
        fullscreen_btn.set_tooltip_text("Open Preview in New Window")
        fullscreen_btn.connect("clicked", self.open_fullscreen)
        header.pack_end(fullscreen_btn)
        
        # Refresh button
        refresh_btn = Gtk.Button.new_from_icon_name("view-refresh-symbolic")
        refresh_btn.set_tooltip_text("Refresh Preview")
        refresh_btn.connect("clicked", self.refresh_preview)
        header.pack_end(refresh_btn)
        
        self.append(header)
        
        # WebKit view
        scrolled = Gtk.ScrolledWindow()
