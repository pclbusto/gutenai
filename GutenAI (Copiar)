class EPUBResourceManager:
    """Maneja la estructura y recursos del EPUB usando ebooklib"""
    
    def __init__(self):
        self.book: Optional[epub.EpubBook] = None
        self.resources: Dict[str, Dict] = {
            'text': [],
            'styles': [],
            'images': [],
            'fonts': [],
            'audio': [],
            'video': [],
            'others': []
        }
        
    def load_epub(self, filepath: str) -> bool:
        """Carga un archivo EPUB y organiza sus recursos"""
        try:
            self.book = epub.read_epub(filepath)
            self._categorize_resources()
            return True
        except Exception as e:
            print(f"Error loading EPUB: {e}")
            return False
    
    def _categorize_resources(self):
        """Categoriza los recursos según ebooklib"""
        if not self.book:
            return
            
        # Reset categories
        for category in self.resources:
            self.resources[category] = []
        
        # Categorize items
        for item in self.book.get_items():
            item_type = item.get_type()
            
            if item_type == ebooklib.ITEM_DOCUMENT:
                self.resources['text'].append({
                    'name': item.get_name(),
                    'item': item,
                    'type': 'html',
                    'in_spine': item in self.book.spine,
                    'icon': '📄'
                })
            elif item_type == ebooklib.ITEM_STYLE:
                self.resources['styles'].append({
                    'name': item.get_name(),
                    'item': item,
                    'type': 'css',
                    'icon': '🎨'
                })
            elif item_type == ebooklib.ITEM_IMAGE:
                self.resources['images'].append({
                    'name': item.get_name(),
                    'item': item,
                    'type': 'image',
                    'icon': '🖼️'
                })
            elif hasattr(item, 'get_name') and any(item.get_name().endswith(ext) for ext in ['.ttf', '.otf', '.woff', '.woff2']):
                self.resources['fonts'].append({
                    'name': item.get_name(),
                    'item': item,
                    'type': 'font',
                    'icon': '🔤'
                })
            elif hasattr(item, 'get_name') and any(item.get_name().endswith(ext) for ext in ['.mp3', '.wav', '.ogg']):
                self.resources['audio'].append({
                    'name': item.get_name(),
                    'item': item,
                    'type': 'audio',
                    'icon': '🎵'
                })
            elif hasattr(item, 'get_name') and any(item.get_name().endswith(ext) for ext in ['.mp4', '.webm', '.ogv']):
                self.resources['video'].append({
                    'name': item.get_name(),
                    'item': item,
                    'type': 'video',
                    'icon': '🎥'
                })
            else:
                self.resources['others'].append({
                    'name': item.get_name() if hasattr(item, 'get_name') else str(item),
                    'item': item,
                    'type': 'other',
                    'icon': '📦'
                })

class SearchDialog(Adw.Window):
    """Diálogo de búsqueda global"""
    
    def __init__(self, parent, epub_manager):
        super().__init__()
        self.set_transient_for(parent)
        self.set_modal(True)
        self.set_title("Global Search")
        self.set_default_size(600, 400)
        
        self.epub_manager = epub_manager
        
        # Setup UI
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        box.set_margin_start(12)
        box.set_margin_end(12)
        box.set_margin_top(12)
        box.set_margin_bottom(12)
        
        # Search entry
        self.search_entry = Gtk.SearchEntry()
        self.search_entry.set_placeholder_text("Search across all book content...")
        self.search_entry.connect("search-changed", self.on_search_changed)
        box.append(self.search_entry)
        
        # Results list
        scrolled = Gtk.ScrolledWindow()
        scrolled.set_vexpand(True)
        
        self.results_list = Gtk.ListBox()
        self.results_list.set_selection_mode(Gtk.SelectionMode.SINGLE)
        scrolled.set_child(self.results_list)
        box.append(scrolled)
        
        self.set_content(box)
        
    def on_search_changed(self, entry):
        """Realizar búsqueda en tiempo real"""
        query = entry.get_text().strip()
        if len(query) < 3:
            return
            
        # Clear previous results
        while True:
            row = self.results_list.get_first_child()
            if row is None:
                break
            self.results_list.remove(row)
        
        # Search through text resources
        for resource in self.epub_manager.resources['text']:
            try:
                content = resource['item'].get_content().decode('utf-8')
                if query.lower() in content.lower():
                    self.add_search_result(resource['name'], content, query)
            except:
                pass
    
    def add_search_result(self, filename, content, query):
        """Agregar resultado de búsqueda"""
        # Find context around the match
        lines = content.split('\n')
        for i, line in enumerate(lines):
            if query.lower() in line.lower():
                context = line.strip()[:100] + "..." if len(line) > 100 else line.strip()
                
                row = Gtk.ListBoxRow()
                box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
                box.set_margin_start(8)
                box.set_margin_end(8)
                box.set_margin_top(8)
                box.set_margin_bottom(8)
                
                title = Gtk.Label(label=filename)
                title.set_halign(Gtk.Align.START)
                title.add_css_class("heading")
                
                snippet = Gtk.Label(label=context)
                snippet.set_halign(Gtk.Align.START)
                snippet.add_css_class("dim-label")
                snippet.set_ellipsize(Pango.EllipsizeMode.END)
                
                box.append(title)
                box.append(snippet)
                row.set_child(box)
                
                self.results_list.append(row)
                break

class CommandPalette(Adw.Window):
    """Command Palette para ejecutar comandos rápidos"""
    
    def __init__(self, parent):
        super().__init__()
        self.set_transient_for(parent)
        self.set_modal(True)
        self.set_title("Command Palette")
        self.set_default_size(500, 300)
        
        self.parent_window = parent
        
        # Commands list
        self.commands = [
            {"name": "Open EPUB File", "action": "open_file", "shortcut": "Ctrl+O"},
            {"name": "Save Current Resource", "action": "save", "shortcut": "Ctrl+S"},
            {"name": "Toggle Left Sidebar", "action": "toggle_left", "shortcut": "Ctrl+1"},
            {"name": "Toggle Right Sidebar", "action": "toggle_right", "shortcut": "Ctrl+2"},
            {"name": "Global Search", "action": "search", "shortcut": "Ctrl+F"},
            {"name": "Preview Fullscreen", "action": "preview_fullscreen", "shortcut": "F11"},
            {"name": "Validate EPUB", "action": "validate", "shortcut": "Ctrl+Shift+V"},
            {"name": "Export EPUB", "action": "export", "shortcut": "Ctrl+E"},
        ]
        
        # Setup UI
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        box.set_margin_start(12)
        box.set_margin_end(12)
        box.set_margin_top(12)
        box.set_margin_bottom(12)
        
        # Command entry
        self.command_entry = Gtk.SearchEntry()
        self.command_entry.set_placeholder_text("Type a command...")
        self.command_entry.connect("search-changed", self.filter_commands)
        self.command_entry.connect("activate", self.execute_selected)
        box.append(self.command_entry)
        
        # Commands list
        scrolled = Gtk.ScrolledWindow()
        scrolled.set_vexpand(True)
        
        self.commands_list = Gtk.ListBox()
        self.commands_list.set_selection_mode(Gtk.SelectionMode.SINGLE)
        self.commands_list.connect("row-activated", self.on_command_selected)
        scrolled.set_child(self.commands_list)
        box.append(scrolled)
        
        self.populate_commands()
        self.set_content(box)
        
    def populate_commands(self):
        """Llenar la lista de comandos"""
        for cmd in self.commands:
            row = Gtk.ListBoxRow()
            row.command = cmd
            
            box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
            box.set_margin_start(8)
            box.set_margin_end(8)
            box.set_margin_top(8)
            box.set_margin_bottom(8)
            
            name_label = Gtk.Label(label=cmd["name"])
            name_label.set_halign(Gtk.Align.START)
            name_label.set_hexpand(True)
            
            shortcut_label = Gtk.Label(label=cmd["shortcut"])
            shortcut_label.add_css_class("dim-label")
            shortcut_label.set_halign(Gtk.Align.END)
            
            box.append(name_label)
            box.append(shortcut_label)
            row.set_child(box)
            
            self.commands_list.append(row)
    
    def filter_commands(self, entry):
        """Filtrar comandos según el texto ingresado"""
        query = entry.get_text().lower()
        
        row = self.commands_list.get_first_child()
        while row:
            next_row = row.get_next_sibling()
            if query in row.command["name"].lower():
                row.set_visible(True)
            else:
                row.set_visible(False)
            row = next_row
    
    def execute_selected(self, entry):
        """Ejecutar el comando seleccionado"""
        selected = self.commands_list.get_selected_row()
        if selected:
            self.execute_command(selected.command)
    
    def on_command_selected(self, listbox, row):
        """Manejar selección de comando"""
        self.execute_command(row.command)
    
    def execute_command(self, command):
        """Ejecutar un comando específico"""
        action = command["action"]
        
        if action == "open_file":
            self.parent_window.open_epub_dialog(None)
        elif action == "save":
            self.parent_window.save_current_resource(None)
        elif action == "toggle_left":
            self.parent_window.toggle_left_sidebar(None)
        elif action == "toggle_right":
            self.parent_window.toggle_right_sidebar(None)
        elif action == "search":
            self.parent_window.show_search(None)
        elif action == "preview_fullscreen":
            self.parent_window.open_preview_fullscreen(None)
        
        self.close()

