        toolbar.set_margin_end(6)
        toolbar.set_margin_top(6)
        toolbar.set_margin_bottom(6)
        
        # Format buttons
        format_buttons = [
            ("format-text-bold-symbolic", "Bold", self.insert_bold),
            ("format-text-italic-symbolic", "Italic", self.insert_italic),
            ("format-text-underline-symbolic", "Underline", self.insert_underline),
        ]
        
        for icon, tooltip, callback in format_buttons:
            btn = Gtk.Button.new_from_icon_name(icon)
            btn.set_tooltip_text(tooltip)
            btn.connect("clicked", callback)
            toolbar.append(btn)
        
        # Separator
        toolbar.append(Gtk.Separator.new(Gtk.Orientation.VERTICAL))
        
        # Heading dropdown
        heading_dropdown = Gtk.DropDown.new_from_strings([
            "Paragraph", "Heading 1", "Heading 2", "Heading 3", "Heading 4"
        ])
        heading_dropdown.set_tooltip_text("Change paragraph style")
        heading_dropdown.connect("notify::selected", self.on_heading_changed)
        toolbar.append(heading_dropdown)
        
        self.append(toolbar)
        
        # Source view with syntax highlighting
        scrolled = Gtk.ScrolledWindow()
        scrolled.set_vexpand(True)
        
        self.source_view = GtkSource.View()
        self.source_buffer = GtkSource.Buffer()
        
        # Setup syntax highlighting
        self.setup_syntax_highlighting()
        
        self.source_view.set_buffer(self.source_buffer)
        self.source_view.set_show_line_numbers(True)
        self.source_view.set_show_line_marks(True)
        self.source_view.set_tab_width(2)
        self.source_view.set_insert_spaces_instead_of_tabs(True)
        self.source_view.set_auto_indent(True)
        self.source_view.set_wrap_mode(Gtk.WrapMode.WORD)
        
        scrolled.set_child(self.source_view)
        self.append(scrolled)
        
        # Connect signals
        self.source_buffer.connect("changed", self.on_text_changed)
        
        self.text_changed_callback = None
    
    def setup_syntax_highlighting(self):
        """Configurar resaltado de sintaxis"""
        language_manager = GtkSource.LanguageManager()
        html_language = language_manager.get_language("html")
        
        if html_language:
            self.source_buffer.set_language(html_language)
        
        # Set color scheme
        style_manager = GtkSource.StyleSchemeManager()
        scheme = style_manager.get_scheme("Adwaita")
        if scheme:
            self.source_buffer.set_style_scheme(scheme)
    
    def set_content(self, content: str):
        """Establecer contenido del editor"""
        self.source_buffer.set_text(content)
    
    def get_content(self) -> str:
        """Obtener contenido del editor"""
        start = self.source_buffer.get_start_iter()
        end = self.source_buffer.get_end_iter()
        return self.source_buffer.get_text(start, end, False)
    
    def on_text_changed(self, buffer):
        """Manejar cambios de texto"""
        if self.text_changed_callback:
            content = self.get_content()
            self.text_changed_callback(content)
    
    def set_text_changed_callback(self, callback):
        """Establecer callback para cambios de texto"""
        self.text_changed_callback = callback
    
    def insert_bold(self, button):
        """Insertar texto en negrita"""
        self.wrap_selection("<strong>", "</strong>")
    
    def insert_italic(self, button):
        """Insertar texto en cursiva"""
        self.wrap_selection("<em>", "</em>")
    
    def insert_underline(self, button):
        """Insertar texto subrayado"""
        self.wrap_selection("<u>", "</u>")
    
    def on_heading_changed(self, dropdown, param):
        """Cambiar estilo de encabezado"""
        selected = dropdown.get_selected()
        tags = ["p", "h1", "h2", "h3", "h4"]
        
        if selected < len(tags):
            tag = tags[selected]
            self.wrap_selection(f"<{tag}>", f"</{tag}>")
    
    def wrap_selection(self, start_tag: str, end_tag: str):
        """Envolver selección con etiquetas"""
        buffer = self.source_buffer
        
        if buffer.get_has_selection():
            start, end = buffer.get_selection_bounds()
            selected_text = buffer.get_text(start, end, False)
            
            new_text = f"{start_tag}{selected_text}{end_tag}"
            buffer.delete(start, end)
            buffer.insert(start, new_text)
        else:
            # Insert at cursor
            cursor = buffer.get_insert()
            iter = buffer.get_iter_at_mark(cursor)
            buffer.insert(iter, f"{start_tag}{end_tag}")
            
            # Move cursor between tags
            new_iter = buffer.get_iter_at_mark(cursor)
            new_iter.backward_chars(len(end_tag))
            buffer.place_cursor(new_iter)

