        if self.temp_dir and os.path.exists(self.temp_dir):
            import shutil
            shutil.rmtree(self.temp_dir, ignore_errors=True)

class GutenAIApplication(Adw.Application):
    """Aplicación principal de Guten.AI"""
    
    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        self.set_application_id("com.gutenai.editor")
        self.set_flags(Gio.ApplicationFlags.HANDLES_OPEN)
        
    def do_activate(self):
        """Activar aplicación"""
        win = self.props.active_window
        if not win:
            win = GutenAIWindow(application=self)
        win.present()
    
    def do_open(self, files, n_files, hint):
        """Abrir archivos desde línea de comandos"""
        self.activate()
        win = self.props.active_window
        
        if win and n_files > 0:
            file_path = files[0].get_path()
            if file_path.endswith('.epub'):
                win.load_epub(file_path)

def main():
    """Punto de entrada principal"""
    import sys
    
    # Check if required modules are available
    try:
        import gi
        # Try different GTK4 versions for compatibility
        try:
            gi.require_version('Gtk', '4.0')
        except ValueError:
            print("Error: GTK4 not found. Please install GTK4.")
            sys.exit(1)
            
        try:
            gi.require_version('Adw', '1')
        except ValueError:
            print("Warning: libadwaita not found. Some features may not work correctly.")
            
        try:
            gi.require_version('WebKit', '6.0')
        except ValueError:
            try:
                gi.require_version('WebKit2', '4.1')
                print("Info: Using WebKit2 4.1 (older version)")
            except ValueError:
                print("Warning: WebKit not found. Preview functionality will be limited.")
        
        # GtkSourceView is optional
        try:
            gi.require_version('GtkSource', '5')
        except ValueError:
            try:
                gi.require_version('GtkSource', '4')
                print("Info: Using GtkSourceView 4 (older version)")
            except ValueError:
                print("Warning: GtkSourceView not found. Syntax highlighting will be limited.")
                
    except ImportError as e:
        print(f"Error: Required GTK modules not found: {e}")
        print("Please install the required system packages:")
        print("  Ubuntu/Debian: sudo apt install python3-gi gir1.2-gtk-4.0 gir1.2-adw-1 gir1.2-webkit2-4.1")
        print("  Fedora: sudo dnf install python3-gobject gtk4-devel libadwaita-devel webkit2gtk4.1-devel")
        sys.exit(1)
    
    try:
        import ebooklib
    except ImportError:
        print("Error: ebooklib not found.")
        print("Install with: pip install ebooklib")
        sys.exit(1)
    
    # Try to start the application
    try:
        app = GutenAIApplication()
        return app.run(sys.argv)
    except Exception as e:
        print(f"Error starting application: {e}")
        print("This might be due to missing system libraries or an incompatible GTK version.")
        print("Please ensure you have GTK4 and libadwaita properly installed.")
        sys.exit(1)

if __name__ == "__main__":
    main()