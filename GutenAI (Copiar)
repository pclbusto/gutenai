            ("command_palette", self.show_command_palette),
            ("toggle_left", self.toggle_left_sidebar),
            ("toggle_right", self.toggle_right_sidebar),
            ("export", self.export_epub),
            ("preview_fullscreen", self.open_preview_fullscreen),
