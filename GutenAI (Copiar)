            ("app.toggle_right", ["<Control>2"]),
            ("app.export", ["<Control>e"]),
            ("app.preview_fullscreen", ["F11"]),
        ]
        
        # Add shortcuts
        for action_name, accelerators in shortcuts:
            trigger = Gtk.ShortcutTrigger.parse_string(accelerators[0])
            action = Gtk.NamedAction.new(action_name)
