        box.append(name_label)
        
        list_item.set_child(box)
    
    def on_factory_bind(self, factory, list_item):
        """Bind data to list item"""
        item_data = list_item.get_item()
        box = list_item.get_child()
        
        icon_label = box.get_first_child()
