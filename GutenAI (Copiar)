        self.append(self.image_info)
        self.append(button_box)
        
        self.current_item = None
    
    def set_image(self, item, temp_path: str):
        """Establecer imagen a mostrar"""
        self.current_item = item
        
        try:
            # Load image
            file = Gio.File.new_for_path(temp_path)
            self.image_display.set_file(file)
            
            # Update info
            size = len(item.get_content())
            size_str = self.format_file_size(size)
            
            # Try to get image dimensions
            try:
                pixbuf = GdkPixbuf.Pixbuf.new_from_file(temp_path)
                width = pixbuf.get_width()
                height = pixbuf.get_height()
                dimensions = f"{width}×{height}"
            except:
                dimensions = "Unknown dimensions"
            
            info_text = f"{item.get_name()}\n{size_str} • {dimensions}"
            self.image_info.set_text(info_text)
            
        except Exception as e:
            self.image_info.set_text(f"Error loading {item.get_name()}\n{str(e)}")
    
    def format_file_size(self, size: int) -> str:
        """Formatear tamaño de archivo"""
        if size < 1024:
            return f"{size} bytes"
        elif size < 1024 * 1024:
            return f"{size/1024:.1f} KB"
        else:
            return f"{size/(1024*1024):.1f} MB"
    
